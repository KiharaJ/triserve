# TriServe — repo-root environment (docker compose + shared defaults).
# Copy to .env — never commit real secrets.

# ---- docker-compose (MySQL 8 + Adminer) ----
MYSQL_ROOT_PASSWORD=triserve_root_dev
MYSQL_DATABASE=triserve
MYSQL_USER=triserve
MYSQL_PASSWORD=triserve_dev
MYSQL_PORT=3306
ADMINER_PORT=8080

# ---- API (also see /api/.env.example — /api/.env is what the API + Prisma read) ----
# mysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="mysql://triserve:triserve_dev@localhost:3306/triserve"
PORT=3000
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
