# TriServe API environment. Copy to /api/.env for local dev.
# Prisma CLI and @nestjs/config both read /api/.env.

# MySQL 8 connection (matches the docker-compose defaults at the repo root).
# mysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="mysql://triserve:triserve_dev@localhost:3306/triserve"

# Seed admin credentials (used by `npx prisma db seed`; dev defaults only —
# override with real values in any non-local environment).
SEED_ADMIN_EMAIL=admin@triserve.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# HTTP port the NestJS app listens on.
PORT=3000

# JWT secrets — generate long random values for anything non-local.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
