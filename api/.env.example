# TriServe API environment. Copy to /api/.env for local dev.
# Prisma CLI and @nestjs/config both read /api/.env.

# MySQL 8 connection (matches the docker-compose defaults at the repo root).
# mysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="mysql://triserve:triserve_dev@localhost:3306/triserve"

# Seed admin credentials (used by `npx prisma db seed`; dev defaults only —
# override with real values in any non-local environment).
SEED_ADMIN_EMAIL=admin@triserve.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# HTTP port the NestJS app listens on.
PORT=3000

# JWT secrets — generate long random values for anything non-local.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Object storage (Task 1.4, §4.12: attachments — signature + photos) ----
#
# STORAGE_DRIVER selects the StorageService implementation; both share the
# exact same StorageService interface (api/src/modules/storage/storage.types.ts),
# so switching drivers is a one-line env change with NO code change:
#
#   local (default) — filesystem under STORAGE_LOCAL_DIR, "presigned" GET
#                      URLs are an HMAC-signed, expiring app route
#                      (GET /attachments/file/:token). Works with no external
#                      services — the right default on a machine with no
#                      Docker/MinIO.
#   s3               — real S3-compatible object storage (MinIO in
#                      docker-compose, or real AWS S3/GCS-S3-interop). Needs
#                      a reachable bucket + credentials below.
STORAGE_DRIVER=local

# --- local driver ---
# Directory the local driver writes objects under (gitignored; NOT committed
# — mirrors how a real bucket's contents aren't committed either).
STORAGE_LOCAL_DIR=.storage
# HMAC secret signing the local driver's "presigned" file-serving tokens —
# generate a long random value for anything non-local.
STORAGE_URL_SECRET=change-me-storage-url-secret

# --- s3 driver (MinIO/S3; see docker-compose.yml's optional `minio` service) ---
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_BUCKET=triserve-attachments
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_REGION=us-east-1
# STORAGE_FORCE_PATH_STYLE=true

# --- shared by both drivers ---
# Upload size cap in bytes (default 25 MiB) — mime allowlist is fixed (PNG/
# JPEG/WEBP images, PDF, MP4) per DESIGN.md §4.12.
STORAGE_MAX_FILE_SIZE_BYTES=26214400
# Presigned/signed GET URL time-to-live, in seconds (default 5 min).
STORAGE_URL_TTL_SECONDS=300
