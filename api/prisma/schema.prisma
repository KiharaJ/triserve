// TriServe Prisma schema.
//
// Conventions (see /docs/DESIGN.md and /README.md):
//   - IDs: CHAR(36) UUIDs. `@default(uuid())` is generated by the Prisma
//     client in the app process (uuid v4) — satisfies the "app-generated,
//     never DB auto-increment" convention while staying declarative.
//   - Timestamps: DATETIME(3) stored in UTC
//   - Money: BIGINT minor units + CHAR(3) currency code — never floats
//   - Soft delete: nullable deleted_at on every row
//   - Audit: created_by / updated_by nullable FK -> users

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums (§3, §4.1)
// ---------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  SERVICE_ADVISOR
  TECHNICIAN
  STOREKEEPER
  WARRANTY_CLERK
  ACCOUNTANT
}

enum UserScope {
  branch
  group
}

/// Every gate-able action funnels through ONE approvals mechanism (§4.11/E8).
enum ApprovalType {
  PRICE_OVERRIDE
  REFUND
  INVENTORY_ADJUSTMENT
  STOCK_TRANSFER
  PURCHASE_ORDER
  WARRANTY_CANCELLATION
  INVOICE_VOID
  REOPEN_JOB
  LARGE_CASH_REFUND
  MANUAL_JOURNAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Product/device category (§4.2): handheld (phones/tablets), consumer
/// electronics (TV/audio), air-con, refrigeration, other. Shared by
/// `models` and `devices` (and later `parts`).
enum DeviceCategory {
  HHP
  CE
  AC
  REF
  OTHER
}

/// Customer's preferred notification language (§4.2) — drives SMS templates.
enum PreferredLanguage {
  EN
  SW
}

/// Account classes of the chart of accounts (§4.9 / E1).
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

/// What operational event produced a journal entry (§4.9 / E1). Only
/// MANUAL is writable today (Task 0.6); the others are switched on with
/// automatic posting in Phase 3 — the enum exists now so no schema rebuild
/// is needed then.
enum JournalSourceType {
  PAYMENT
  GRN
  SUPPLIER_PAYMENT
  WARRANTY
  ADJUSTMENT
  MANUAL
}

// ---------------------------------------------------------------------------
// Org / reference (§4.1)
// ---------------------------------------------------------------------------

model Company {
  id           String  @id @default(uuid()) @db.Char(36)
  name         String  @db.VarChar(255)
  legalName    String? @map("legal_name") @db.VarChar(255)
  tin          String? @db.VarChar(50)
  vrn          String? @db.VarChar(50)
  baseCurrency String  @default("TZS") @map("base_currency") @db.Char(3)
  logoUrl      String? @map("logo_url") @db.VarChar(500)
  address      String? @db.VarChar(500)
  phone        String? @db.VarChar(50)
  active       Boolean @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("CompanyUpdatedBy", fields: [updatedById], references: [id])

  branches       Branch[]
  users          User[]
  currencies     Currency[]
  paymentMethods PaymentMethod[]
  faultCodes     FaultCode[]
  repairActions  RepairAction[]
  taxRates       TaxRate[]
  approvals      Approval[]
  approvalRules  ApprovalRule[]
  accounts       ChartOfAccount[]
  journalEntries JournalEntry[]
  customers      Customer[]
  devices        Device[]
  deviceModels   DeviceModel[]

  workflowStates      WorkflowState[]
  workflowTransitions WorkflowTransition[]

  @@map("companies")
}

model Branch {
  id        String  @id @default(uuid()) @db.Char(36)
  companyId String  @map("company_id") @db.Char(36)
  code      String  @db.VarChar(20)
  name      String  @db.VarChar(255)
  isHq      Boolean @default(false) @map("is_hq")
  address   String? @db.VarChar(500)
  phone     String? @db.VarChar(50)
  tzRegion  String? @map("tz_region") @db.VarChar(100)
  active    Boolean @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("BranchCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("BranchUpdatedBy", fields: [updatedById], references: [id])

  company            Company        @relation(fields: [companyId], references: [id])
  homeUsers          User[]         @relation("UserHomeBranch")
  approvals          Approval[]
  journalEntries     JournalEntry[]
  preferredCustomers Customer[]     @relation("CustomerPreferredBranch")

  @@unique([companyId, code])
  @@map("branches")
}

model User {
  id           String    @id @default(uuid()) @db.Char(36)
  companyId    String    @map("company_id") @db.Char(36)
  fullName     String    @map("full_name") @db.VarChar(255)
  initials     String?   @db.VarChar(10)
  email        String    @unique @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole
  homeBranchId String?   @map("home_branch_id") @db.Char(36)
  scope        UserScope @default(branch)
  totpSecret   String?   @map("totp_secret") @db.VarChar(255)
  totpEnabled  Boolean   @default(false) @map("totp_enabled")
  active       Boolean   @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("UserUpdatedBy", fields: [updatedById], references: [id])

  company    Company @relation(fields: [companyId], references: [id])
  homeBranch Branch? @relation("UserHomeBranch", fields: [homeBranchId], references: [id])

  // Inverse sides of audit relations
  createdUsers          User[]          @relation("UserCreatedBy")
  updatedUsers          User[]          @relation("UserUpdatedBy")
  createdCompanies      Company[]       @relation("CompanyCreatedBy")
  updatedCompanies      Company[]       @relation("CompanyUpdatedBy")
  createdBranches       Branch[]        @relation("BranchCreatedBy")
  updatedBranches       Branch[]        @relation("BranchUpdatedBy")
  createdCurrencies     Currency[]      @relation("CurrencyCreatedBy")
  updatedCurrencies     Currency[]      @relation("CurrencyUpdatedBy")
  createdPaymentMethods PaymentMethod[] @relation("PaymentMethodCreatedBy")
  updatedPaymentMethods PaymentMethod[] @relation("PaymentMethodUpdatedBy")
  createdFaultCodes     FaultCode[]     @relation("FaultCodeCreatedBy")
  updatedFaultCodes     FaultCode[]     @relation("FaultCodeUpdatedBy")
  createdRepairActions  RepairAction[]  @relation("RepairActionCreatedBy")
  updatedRepairActions  RepairAction[]  @relation("RepairActionUpdatedBy")
  createdTaxRates       TaxRate[]       @relation("TaxRateCreatedBy")
  updatedTaxRates       TaxRate[]       @relation("TaxRateUpdatedBy")
  createdCustomers      Customer[]      @relation("CustomerCreatedBy")
  updatedCustomers      Customer[]      @relation("CustomerUpdatedBy")
  createdDevices        Device[]        @relation("DeviceCreatedBy")
  updatedDevices        Device[]        @relation("DeviceUpdatedBy")
  createdDeviceModels   DeviceModel[]   @relation("DeviceModelCreatedBy")
  updatedDeviceModels   DeviceModel[]   @relation("DeviceModelUpdatedBy")

  createdWorkflowStates      WorkflowState[]      @relation("WorkflowStateCreatedBy")
  updatedWorkflowStates      WorkflowState[]      @relation("WorkflowStateUpdatedBy")
  createdWorkflowTransitions WorkflowTransition[] @relation("WorkflowTransitionCreatedBy")
  updatedWorkflowTransitions WorkflowTransition[] @relation("WorkflowTransitionUpdatedBy")

  sessions             Session[]
  requestedApprovals   Approval[]     @relation("ApprovalRequestedBy")
  decidedApprovals     Approval[]     @relation("ApprovalApprovedBy")
  postedJournalEntries JournalEntry[] @relation("JournalEntryPostedBy")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Approvals (§4.11 / E8, Task 0.5) — ONE generic gate for every sensitive
// action (refunds, voids, big discounts, POs, adjustments, job reopens, …).
// Later modules call ApprovalsService.request(...) BEFORE performing a gated
// action and proceed only once the row is APPROVED.
// ---------------------------------------------------------------------------

model Approval {
  id        String       @id @default(uuid()) @db.Char(36)
  companyId String       @map("company_id") @db.Char(36)
  branchId  String       @map("branch_id") @db.Char(36)
  type      ApprovalType

  /// The entity awaiting approval. NULLABLE on purpose: an approval may
  /// PRECEDE the entity it gates (e.g. approve a refund before the credit
  /// note row exists) — the caller backfills ref_id afterwards.
  refType String? @map("ref_type") @db.VarChar(100)
  refId   String? @map("ref_id") @db.Char(36)

  /// The proposed change (free-form, per type): e.g. {"amount": 15000000,
  /// "currency": "TZS"} for a REFUND, {"percent": 12} for a PRICE_OVERRIDE.
  payloadJson Json? @map("payload_json")

  requestedById String         @map("requested_by") @db.Char(36)
  approvedById  String?        @map("approved_by") @db.Char(36)
  status        ApprovalStatus @default(PENDING)
  /// Requester's justification (required, §4.11); a rejection reason
  /// replaces it on decide (the original is preserved in the audit trail).
  reason        String         @db.Text
  requestedAt   DateTime       @default(now()) @map("requested_at") @db.DateTime(3)
  decidedAt     DateTime?      @map("decided_at") @db.DateTime(3)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  company     Company @relation(fields: [companyId], references: [id])
  branch      Branch  @relation(fields: [branchId], references: [id])
  requestedBy User    @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?   @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])

  @@index([companyId, status, type])
  @@index([companyId, branchId, status])
  @@index([refType, refId])
  @@map("approvals")
}

/// Per-company config backing ApprovalsService.isRequired(): when does a
/// given action type need a manager's sign-off? Thresholds are OR-ed —
/// amount >= threshold_amount, or percent >= threshold_percent. Amounts are
/// BIGINT minor units of the company base currency (money convention).
/// No rule / enabled=false → the action never requires approval.
model ApprovalRule {
  id               String       @id @default(uuid()) @db.Char(36)
  companyId        String       @map("company_id") @db.Char(36)
  type             ApprovalType
  thresholdAmount  BigInt?      @map("threshold_amount") @db.BigInt
  thresholdPercent Decimal?     @map("threshold_percent") @db.Decimal(6, 3)
  enabled          Boolean      @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, type])
  @@map("approval_rules")
}

// ---------------------------------------------------------------------------
// Audit log (§4.8, Task 0.4) — append-only record of every mutation
// ---------------------------------------------------------------------------

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  TRANSITION
  LOGIN
  APPROVE
  REJECT
}

/// Append-only. Written automatically by the audit Prisma extension
/// (api/src/prisma/audit.extension.ts) inside the same transaction as the
/// intercepted mutation; never updated or deleted (the extension throws on
/// any update/delete attempt against this model).
///
/// DELIBERATELY NO FOREIGN KEYS: audit rows must outlive the actors and
/// entities they describe (a hard-deleted user/branch must not cascade into
/// — or block — its audit trail). actor_user_id / entity_id are plain
/// CHAR(36) references resolved at read time.
model AuditLog {
  id          String      @id @default(uuid()) @db.Char(36)
  companyId   String      @map("company_id") @db.Char(36)
  branchId    String?     @map("branch_id") @db.Char(36)
  /// Null for system/seed writes made outside any request context.
  actorUserId String?     @map("actor_user_id") @db.Char(36)
  /// Prisma model name of the mutated entity, e.g. "Branch".
  entityType  String      @map("entity_type") @db.VarChar(100)
  entityId    String      @map("entity_id") @db.Char(36)
  action      AuditAction
  beforeJson  Json?       @map("before_json")
  afterJson   Json?       @map("after_json")
  at          DateTime    @default(now()) @db.DateTime(3)
  ip          String?     @db.VarChar(64)
  userAgent   String?     @map("user_agent") @db.VarChar(500)

  @@index([companyId, entityType, entityId])
  @@index([companyId, at])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Sessions — device/login history + refresh-token store (§11 / E18, Task 0.2)
// ---------------------------------------------------------------------------

model Session {
  id               String    @id @default(uuid()) @db.Char(36)
  userId           String    @map("user_id") @db.Char(36)
  // SHA-256 hex of the current (rotated) refresh token — the raw token is
  // never stored. A mismatch means the token was rotated/revoked → reject.
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?   @map("user_agent") @db.VarChar(500)
  ip               String?   @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  lastUsedAt       DateTime  @default(now()) @map("last_used_at") @db.DateTime(3)
  revokedAt        DateTime? @map("revoked_at") @db.DateTime(3)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Accounting ledger (§4.9 / E1, Task 0.6) — TABLES ONLY for now.
//
// The double-entry tables exist from Phase 0 so automatic posting can be
// switched on in Phase 3 without a schema rebuild. Every entry is written
// EXCLUSIVELY through JournalService.post(), which enforces
// SUM(debit) == SUM(credit) in code and writes header + lines atomically.
// Manual journals are approval-gated (§4.11, type MANUAL_JOURNAL).
// ---------------------------------------------------------------------------

model ChartOfAccount {
  id        String      @id @default(uuid()) @db.Char(36)
  companyId String      @map("company_id") @db.Char(36)
  /// e.g. 1000 Cash, 1010 Bank, 1200 AR–Samsung, 2000 AP–Suppliers, 5000 COGS
  code      String      @db.VarChar(20)
  name      String      @db.VarChar(255)
  type      AccountType
  isActive  Boolean     @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  company Company       @relation(fields: [companyId], references: [id])
  lines   JournalLine[]

  @@unique([companyId, code])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id        String  @id @default(uuid()) @db.Char(36)
  companyId String  @map("company_id") @db.Char(36)
  /// Nullable: company-level entries (e.g. year-end adjustments) have no branch.
  branchId  String? @map("branch_id") @db.Char(36)

  entryDate  DateTime          @map("entry_date") @db.Date
  sourceType JournalSourceType @map("source_type")
  /// Id of the operational row that produced this entry (payment, GRN, …).
  /// For MANUAL entries: the id of the MANUAL_JOURNAL approval that gated it.
  sourceId   String?           @map("source_id") @db.Char(36)
  memo       String?           @db.VarChar(500)
  postedById String            @map("posted_by") @db.Char(36)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  company  Company       @relation(fields: [companyId], references: [id])
  branch   Branch?       @relation(fields: [branchId], references: [id])
  postedBy User          @relation("JournalEntryPostedBy", fields: [postedById], references: [id])
  lines    JournalLine[]

  @@index([companyId, entryDate])
  @@index([companyId, sourceType, sourceId])
  @@map("journal_entries")
}

/// The debits/credits of one entry. No company_id on purpose: lines are
/// reached ONLY via their (company-scoped) entry — see
/// company-scope.extension.ts. Money is BIGINT minor units; exactly one of
/// debit/credit is non-zero per line (enforced by JournalService.post).
model JournalLine {
  id        String @id @default(uuid()) @db.Char(36)
  entryId   String @map("entry_id") @db.Char(36)
  accountId String @map("account_id") @db.Char(36)
  debit     BigInt @default(0) @db.BigInt
  credit    BigInt @default(0) @db.BigInt
  currency  String @db.Char(3)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  /// Restrict (never cascade): the ledger is append-only — an entry with
  /// lines cannot be deleted out from under them.
  entry   JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Restrict)
  account ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId])
  @@map("journal_lines")
}

// ---------------------------------------------------------------------------
// Customers & devices (§4.2, Task 1.1) — CRM 360 (E2) / device history (E3)
// foundations.
//
// SCOPING DECISION (documented): customers and devices are COMPANY-scoped,
// deliberately NOT branch-scoped. A customer belongs to the group and can be
// served at any branch (§4.2); `preferred_branch_id` is a CRM preference /
// analytics dimension, not an access boundary — branch-scoping would hide a
// walk-in customer's record (and their device history) from every other
// branch's front desk. Models are company-level config (like fault codes).
// ---------------------------------------------------------------------------

/// The `models` lookup (§4.2) — normalises the messy free-text model column
/// ("A05", "S23 Ultra", "UA40M5000", …). Named DeviceModel in Prisma to
/// avoid the confusing `prisma.model` delegate; the table is `models`.
model DeviceModel {
  id        String         @id @default(uuid()) @db.Char(36)
  companyId String         @map("company_id") @db.Char(36)
  modelCode String         @map("model_code") @db.VarChar(100)
  category  DeviceCategory
  brand     String         @default("Samsung") @db.VarChar(100)
  active    Boolean        @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("DeviceModelCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("DeviceModelUpdatedBy", fields: [updatedById], references: [id])

  company Company  @relation(fields: [companyId], references: [id])
  devices Device[]

  @@unique([companyId, brand, modelCode])
  @@map("models")
}

/// Customers (§4.2 / E2). Lean record — the rich 360 profile is assembled by
/// the API from related tables later. `phone` keeps the exact user input;
/// `phone_normalized` / `alt_phone_normalized` hold the canonical E.164-ish
/// form produced by normalizePhone() and are what phone search hits.
model Customer {
  id                 String            @id @default(uuid()) @db.Char(36)
  companyId          String            @map("company_id") @db.Char(36)
  name               String            @db.VarChar(255)
  phone              String?           @db.VarChar(50)
  phoneNormalized    String?           @map("phone_normalized") @db.VarChar(50)
  altPhone           String?           @map("alt_phone") @db.VarChar(50)
  altPhoneNormalized String?           @map("alt_phone_normalized") @db.VarChar(50)
  email              String?           @db.VarChar(255)
  location           String?           @db.VarChar(255)
  dealerName         String?           @map("dealer_name") @db.VarChar(255)
  isDealer           Boolean           @default(false) @map("is_dealer")
  preferredBranchId  String?           @map("preferred_branch_id") @db.Char(36)
  preferredLanguage  PreferredLanguage @default(EN) @map("preferred_language")
  /// 1–5 internal customer rating/flag.
  rating             Int?              @db.TinyInt
  notes              String?           @db.Text

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("CustomerUpdatedBy", fields: [updatedById], references: [id])

  company         Company  @relation(fields: [companyId], references: [id])
  preferredBranch Branch?  @relation("CustomerPreferredBranch", fields: [preferredBranchId], references: [id])
  devices         Device[]

  @@index([companyId, phone])
  @@index([companyId, phoneNormalized])
  @@index([companyId, altPhoneNormalized])
  @@index([companyId, name])
  @@map("customers")
}

/// Devices (§4.2 / E3). `customer_id` is the CURRENT owner — ownership can
/// change, so `imei_serial` is indexed but deliberately NOT unique (the same
/// physical device may be re-registered; history persists across owners).
/// `model` stays free-text (legacy data is messy); `model_id` is the
/// normalised link to `models` when resolvable.
model Device {
  id         String         @id @default(uuid()) @db.Char(36)
  companyId  String         @map("company_id") @db.Char(36)
  customerId String         @map("customer_id") @db.Char(36)
  brand      String         @default("Samsung") @db.VarChar(100)
  model      String?        @db.VarChar(150)
  modelId    String?        @map("model_id") @db.Char(36)
  category   DeviceCategory
  /// IMEI or serial number; nullable (some CE/AC units lack one). Stored
  /// cleaned (scientific-notation legacy values expanded, separators
  /// stripped, uppercased) — see normalizeImeiSerial().
  imeiSerial String?        @map("imei_serial") @db.VarChar(100)
  color      String?        @db.VarChar(50)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("DeviceCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("DeviceUpdatedBy", fields: [updatedById], references: [id])

  company     Company      @relation(fields: [companyId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])
  deviceModel DeviceModel? @relation(fields: [modelId], references: [id])

  @@index([companyId, imeiSerial])
  @@index([customerId])
  @@map("devices")
}

// ---------------------------------------------------------------------------
// Configurable workflow engine (§4.10 / E7, Task 1.2)
//
// Job statuses and their allowed transitions are DATA, not a hardcoded enum,
// so each company can configure its own flow. The §5 lifecycle is the SEEDED
// DEFAULT workflow. Task 1.3 makes jobs.status an FK → workflow_states and
// validates every POST /jobs/{id}/transition through workflow_transitions.
// ---------------------------------------------------------------------------

/// One job status (a Kanban column). Unique per (company, code);
/// `is_initial` marks where new jobs start, `is_terminal` where they end,
/// `sort_order` drives board column ordering.
model WorkflowState {
  id         String  @id @default(uuid()) @db.Char(36)
  companyId  String  @map("company_id") @db.Char(36)
  code       String  @db.VarChar(50)
  label      String  @db.VarChar(100)
  isInitial  Boolean @default(false) @map("is_initial")
  isTerminal Boolean @default(false) @map("is_terminal")
  sortOrder  Int     @default(0) @map("sort_order")
  active     Boolean @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("WorkflowStateCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("WorkflowStateUpdatedBy", fields: [updatedById], references: [id])

  company         Company              @relation(fields: [companyId], references: [id])
  transitionsFrom WorkflowTransition[] @relation("TransitionFromState")
  transitionsTo   WorkflowTransition[] @relation("TransitionToState")

  @@unique([companyId, code])
  @@map("workflow_states")
}

/// One legal edge in the state machine. `required_permission` is a
/// @triserve/shared permission string the acting user must hold (NULL = any
/// authenticated user with access to the job); `requires_approval` hooks the
/// generic approvals framework (§4.11); `guard_code` names a code-side guard
/// function in the workflow guard registry (e.g. 'ow_quote_approved') so new
/// business rules plug in WITHOUT schema changes.
model WorkflowTransition {
  id                 String  @id @default(uuid()) @db.Char(36)
  companyId          String  @map("company_id") @db.Char(36)
  fromStateId        String  @map("from_state_id") @db.Char(36)
  toStateId          String  @map("to_state_id") @db.Char(36)
  requiredPermission String? @map("required_permission") @db.VarChar(100)
  requiresApproval   Boolean @default(false) @map("requires_approval")
  guardCode          String? @map("guard_code") @db.VarChar(100)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("WorkflowTransitionCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("WorkflowTransitionUpdatedBy", fields: [updatedById], references: [id])

  company   Company       @relation(fields: [companyId], references: [id])
  fromState WorkflowState @relation("TransitionFromState", fields: [fromStateId], references: [id])
  toState   WorkflowState @relation("TransitionToState", fields: [toStateId], references: [id])

  @@unique([companyId, fromStateId, toStateId])
  @@index([toStateId])
  @@map("workflow_transitions")
}

