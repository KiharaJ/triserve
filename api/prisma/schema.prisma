model TaxRate {
  id        String  @id @default(uuid()) @db.Char(36)
  companyId String  @map("company_id") @db.Char(36)
  code      String  @db.VarChar(30)
  label     String  @db.VarChar(255)
  percent   Decimal @db.Decimal(6, 3)
  active    Boolean @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("TaxRateCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("TaxRateUpdatedBy", fields: [updatedById], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@map("tax_rates")
}

// ---------------------------------------------------------------------------
// Jobs (§4.3 / §5, Task 1.3) — the heart of the system.
//
// A job is a device brought in for service. It is created at the workflow
// INITIAL state (RECEIVED), carries a branch-prefixed human `job_no`
// (generated concurrency-safely via JobCounter), and moves through the
// configurable workflow (Task 1.2) EXCLUSIVELY via POST /jobs/{id}/transition
// — validated by WorkflowService. Jobs are COMPANY- AND BRANCH-scoped (a
// branch user only sees their branch; TECHNICIANs are further restricted in
// the service to jobs assigned to them). Mutations are audited; state moves
// additionally emit a semantic TRANSITION audit row.
//
// claim_id / invoice_id are nullable columns reserved for later phases
// (warranty_claims / invoices tables don't exist yet) — plain CHAR(36) with
// NO FK, mirroring how those links are backfilled once those modules land.
model Job {
  id                 String         @id @default(uuid()) @db.Char(36)
  companyId          String         @map("company_id") @db.Char(36)
  /// Human-friendly, branch-prefixed, unique per company: `DAR-2026-000123`.
  jobNo              String         @map("job_no") @db.VarChar(50)
  /// Samsung SO / job-card number — stored as a CLEAN string (Excel
  /// scientific-notation like `4.29260291E9` is expanded on intake).
  soNumber           String?        @map("so_number") @db.VarChar(100)
  branchId           String         @map("branch_id") @db.Char(36)
  customerId         String         @map("customer_id") @db.Char(36)
  deviceId           String         @map("device_id") @db.Char(36)
  bookedById         String         @map("booked_by") @db.Char(36)
  assignedEngineerId String?        @map("assigned_engineer_id") @db.Char(36)
  warrantyStatus     WarrantyStatus @default(UNKNOWN) @map("warranty_status")
  faultReported      String?        @map("fault_reported") @db.Text
  faultCodeId        String?        @map("fault_code_id") @db.Char(36)
  techReport         String?        @map("tech_report") @db.Text
  /// FK → workflow_states — the job's current lifecycle status (§4.10).
  stateId            String         @map("state_id") @db.Char(36)
  receivedAt         DateTime       @map("received_at") @db.DateTime(3)
  readyAt            DateTime?      @map("ready_at") @db.DateTime(3)
  dispatchedAt       DateTime?      @map("dispatched_at") @db.DateTime(3)
  dispatchedById     String?        @map("dispatched_by") @db.Char(36)
  receivedByCustomer String?        @map("received_by_customer") @db.VarChar(255)
  waybillNo          String?        @map("waybill_no") @db.VarChar(100)
  /// Reserved for later phases (no FK — target tables don't exist yet).
  claimId            String?        @map("claim_id") @db.Char(36)
  invoiceId          String?        @map("invoice_id") @db.Char(36)
  notes              String?        @db.Text

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)

  company          Company       @relation(fields: [companyId], references: [id])
  branch           Branch        @relation(fields: [branchId], references: [id])
  customer         Customer      @relation(fields: [customerId], references: [id])
  device           Device        @relation(fields: [deviceId], references: [id])
  bookedBy         User          @relation("JobBookedBy", fields: [bookedById], references: [id])
  assignedEngineer User?         @relation("JobAssignedEngineer", fields: [assignedEngineerId], references: [id])
  faultCode        FaultCode?    @relation(fields: [faultCodeId], references: [id])
  state            WorkflowState @relation(fields: [stateId], references: [id])
  dispatchedBy     User?         @relation("JobDispatchedBy", fields: [dispatchedById], references: [id])
  createdBy        User?         @relation("JobCreatedBy", fields: [createdById], references: [id])
  updatedBy        User?         @relation("JobUpdatedBy", fields: [updatedById], references: [id])

  @@unique([companyId, jobNo])
  @@index([companyId, branchId, stateId])
  @@index([companyId, assignedEngineerId])
  @@index([companyId, receivedAt])
  @@index([customerId])
  @@index([deviceId])
  @@map("jobs")
}

/// Per-(company, branch, year) monotonic counter backing concurrency-safe
/// job_no generation (§4.3). Incremented atomically via a single MySQL
/// `INSERT … ON DUPLICATE KEY UPDATE next_seq = LAST_INSERT_ID(next_seq + 1)`
/// inside an interactive transaction, so N parallel job creates get N
/// distinct sequential numbers with no dupes (the @@unique row lock
/// serializes the increment). Accessed ONLY via raw SQL — it deliberately
/// has NO relations and is NOT audited (an internal sequence, not business
/// data). The unique constraint on jobs.job_no is the ultimate backstop.
model JobCounter {
  id        String @id @default(uuid()) @db.Char(36)
  companyId String @map("company_id") @db.Char(36)
  branchId  String @map("branch_id") @db.Char(36)
  year      Int
  nextSeq   Int    @default(0) @map("next_seq")

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@unique([companyId, branchId, year])
  @@map("job_counters")
}

// ---------------------------------------------------------------------------
// Attachments (§4.12 / E4, Task 1.4) — polymorphic file store.
//
// Files themselves NEVER touch the DB: `file_url` holds the object-storage
// KEY (e.g. `{companyId}/JOB/{jobId}/{uuid}.jpg`), not a browsable URL —
// StorageService mints a fresh, short-lived presigned/signed GET URL on
// every read (list/upload response), so the API is the only thing that ever
// needs real storage credentials.
//
// owner_type/owner_id is a polymorphic reference (like AuditLog's
// entityType/entityId) — deliberately NOT an FK, since one column can't
// point at five different tables. Existence + access is validated in
// AttachmentsService before the row is written (load the JOB/CUSTOMER/
// DEVICE and check company/branch scope); GRN/INVOICE owners are accepted
// by the enum for forward-compatibility with §4.4b/§4.6 but those tables
// don't exist yet in this phase, so no existence check runs for them yet —
// add one the day those modules land.
// ---------------------------------------------------------------------------

enum AttachmentOwnerType {
  JOB
  CUSTOMER
  DEVICE
  GRN
  INVOICE
}

enum AttachmentKind {
  SIGNATURE
  PHOTO_BEFORE
  PHOTO_AFTER
  VIDEO
  WARRANTY_CARD
  PURCHASE_RECEIPT
  DOC
}

/// Polymorphic file store (§4.12). No `deleted_at`: DELETE /attachments/{id}
/// is a REAL delete of both the object AND the row (the design explicitly
/// wants the object gone, not just hidden) — the audit extension's DELETE
/// row is the historical record, not a soft-delete flag.
///
/// BRANCH SCOPING CHOICE (documented tradeoff): `branch_id` is derived from
/// the owning JOB at upload time (nullable — CUSTOMER/DEVICE owners are
/// company-level, so their attachments carry branch_id = NULL and stay
/// visible group-wide within the company, matching how Customer/Device
/// themselves are NOT branch-scoped). Attachment is deliberately **NOT**
/// added to `BRANCH_SCOPED_MODELS` in company-scope.extension.ts: that
/// extension tightens reads with a blunt `branchId = user.homeBranchId`
/// equality clause, which would also exclude the legitimate `branchId =
/// NULL` (company-level) rows for a branch-scoped user — the opposite of
/// what §4.12 wants. Instead AttachmentsService applies the correct
/// `OR: [{ branchId: null }, { branchId: user.homeBranchId }]` filter
/// itself for scope='branch' users, in both list() and the single-row
/// lookup used by delete(). Company scoping (`company_id`) IS handled by
/// the generic extension as normal (Attachment IS in COMPANY_SCOPED_MODELS).
model Attachment {
  id           String              @id @default(uuid()) @db.Char(36)
  companyId    String              @map("company_id") @db.Char(36)
  /// Derived from the owning Job at upload time; NULL for company-level
  /// owners (CUSTOMER/DEVICE) — see branch-scoping note above.
  branchId     String?             @map("branch_id") @db.Char(36)
  ownerType    AttachmentOwnerType @map("owner_type")
  ownerId      String              @map("owner_id") @db.Char(36)
  kind         AttachmentKind
  /// Object-storage KEY (not a public URL) — see file header note.
  fileUrl      String              @map("file_url") @db.VarChar(1024)
  fileName     String              @map("file_name") @db.VarChar(255)
  mimeType     String              @map("mime_type") @db.VarChar(100)
  sizeBytes    Int                 @map("size_bytes")
  uploadedById String              @map("uploaded_by") @db.Char(36)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  company    Company @relation(fields: [companyId], references: [id])
  branch     Branch? @relation(fields: [branchId], references: [id])
  uploadedBy User    @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([companyId, ownerType, ownerId])
  @@index([companyId, branchId])
  @@map("attachments")
}

// ---------------------------------------------------------------------------
// Parts / inventory (§4.4 / E10, Task 2.1) — the ledger-backed stock model.
//
// THREE tables, one invariant:
//   - `parts`           — the company-level catalogue (one row per part
//                         number), like `models`: COMPANY-scoped, NOT branch.
//   - `inventory`       — stock buckets PER (branch, part): the materialized
//                         view read by every screen. COMPANY- AND BRANCH-scoped.
//   - `stock_movements` — the APPEND-ONLY ledger that is the SOURCE OF TRUTH
//                         for the buckets (like journal_lines for the ledger).
//
// Available stock (E10) = qty_on_hand − qty_reserved − qty_damaged. Every
// stock change goes through InventoryService.applyMovement(), which writes ONE
// stock_movements row AND updates the inventory buckets ATOMICALLY in a single
// transaction — so the buckets can always be rebuilt from the ledger
// (reconcile()), and no screen ever sees a movement without its bucket effect.
//
// Neither `inventory` nor `stock_movements` is in AUDITED_MODELS: the movement
// ledger IS inventory's audit trail (every bucket change is a movement row
// carrying moved_by/moved_at/reason), and auditing rows written inside
// applyMovement()'s own transaction would violate the audit extension's
// "no caller-managed transaction" rule. `parts` (infrequent catalogue edits,
// never written inside a tx) IS audited like `models`.
// ---------------------------------------------------------------------------

/// What operational event produced a stock movement (§4.4). Signed `qty`:
/// RECEIPT/TRANSFER_IN/RETURN/UNRESERVE are inbound (+), CONSUMPTION/
/// TRANSFER_OUT/SALE/SUPPLIER_RETURN/RESERVE/DAMAGE are outbound of their
/// bucket (−). ADJUSTMENT can be either sign (stock count correction).
enum StockMovementType {
  RECEIPT
  CONSUMPTION
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
  SALE
  RETURN
  SUPPLIER_RETURN
  RESERVE
  UNRESERVE
  DAMAGE
}

/// The kind of source document a movement links back to via ref_id (§4.4).
/// GRN links a receipt to its goods-received note (and through it the PO /
/// supplier). Tables for JOB exist; GRN/TRANSFER/POS_SALE arrive in later
/// Phase-2/3 tasks — the enum is complete now so no rebuild is needed then.
enum StockRefType {
  JOB
  GRN
  TRANSFER
  POS_SALE
  COUNT
  ADJUSTMENT
}

/// The spare-parts catalogue (§4.4). One row per part number per company.
/// Money is BIGINT minor units + a currency: `unit_cost_usd` is the landed
/// cost in USD cents (Samsung parts are priced in USD), `default_sell_price_tzs`
/// the OW counter price in TZS minor units. `compatible_models` is a JSON
/// array of model codes it fits (§4.4 "text[] / join") — kept denormalized for
/// now; a `part_models` join can replace it without touching callers.
model Part {
  id                  String         @id @default(uuid()) @db.Char(36)
  companyId           String         @map("company_id") @db.Char(36)
  partNumber          String         @map("part_number") @db.VarChar(100)
  description         String         @db.VarChar(500)
  category            DeviceCategory
  unitCostUsd         BigInt?        @map("unit_cost_usd") @db.BigInt
  sellPriceTzs        BigInt?        @map("default_sell_price_tzs") @db.BigInt
  compatibleModels    Json?          @map("compatible_models")
  isSerialized        Boolean        @default(false) @map("is_serialized")
  /// Forward-compat (§4.4b, Task 2.5): drives suggested-reorder grouping.
  /// Plain CHAR(36) with NO FK yet — the `suppliers` table lands in Task 2.5,
  /// which adds the constraint (mirrors jobs.claim_id / invoice_id).
  preferredSupplierId String?        @map("preferred_supplier_id") @db.Char(36)
  active              Boolean        @default(true)

  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdById String?   @map("created_by") @db.Char(36)
  updatedById String?   @map("updated_by") @db.Char(36)
  createdBy   User?     @relation("PartCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("PartUpdatedBy", fields: [updatedById], references: [id])

  company   Company         @relation(fields: [companyId], references: [id])
  inventory Inventory[]
  movements StockMovement[]

  @@unique([companyId, partNumber])
  @@index([companyId, category])
  @@map("parts")
}

/// Stock buckets for one part at one branch (§4.4 / E10). The `qty_*` columns
/// are the materialized projection of `stock_movements`; available stock is
/// derived (`qty_on_hand − qty_reserved − qty_damaged`) in the service, never
/// stored. `reorder_level` triggers the low-stock alert / suggested reorder.
model Inventory {
  id             String  @id @default(uuid()) @db.Char(36)
  companyId      String  @map("company_id") @db.Char(36)
  branchId       String  @map("branch_id") @db.Char(36)
  partId         String  @map("part_id") @db.Char(36)
  binLocation    String? @map("bin_location") @db.VarChar(50)
  qtyOnHand      Int     @default(0) @map("qty_on_hand")
  qtyReserved    Int     @default(0) @map("qty_reserved")
  qtyInTransitIn Int     @default(0) @map("qty_in_transit_in")
  qtyDamaged     Int     @default(0) @map("qty_damaged")
  reorderLevel   Int     @default(0) @map("reorder_level")

  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  createdById String?  @map("created_by") @db.Char(36)
  updatedById String?  @map("updated_by") @db.Char(36)
  createdBy   User?    @relation("InventoryCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?    @relation("InventoryUpdatedBy", fields: [updatedById], references: [id])

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  part    Part    @relation(fields: [partId], references: [id])

  @@unique([branchId, partId])
  @@index([companyId, branchId])
  @@index([partId])
  @@map("inventory")
}

/// Append-only stock ledger (§4.4) — the source of truth behind every bucket.
/// NEVER updated or deleted. `qty` is signed; `ref_type`/`ref_id` link the
/// causing document (job/GRN/transfer/count); `unit_cost`+`cost_currency`
/// capture cost at the time of the movement (BIGINT minor units) for
/// valuation. `reason` is required for ADJUSTMENT/DAMAGE (enforced in service).
model StockMovement {
  id           String            @id @default(uuid()) @db.Char(36)
  companyId    String            @map("company_id") @db.Char(36)
  branchId     String            @map("branch_id") @db.Char(36)
  partId       String            @map("part_id") @db.Char(36)
  movementType StockMovementType @map("movement_type")
  qty          Int
  refType      StockRefType?     @map("ref_type")
  refId        String?           @map("ref_id") @db.Char(36)
  unitCost     BigInt?           @map("unit_cost") @db.BigInt
  costCurrency String?           @map("cost_currency") @db.Char(3)
  reason       String?           @db.Text
  movedById    String            @map("moved_by") @db.Char(36)
  movedAt      DateTime          @default(now()) @map("moved_at") @db.DateTime(3)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  part    Part    @relation(fields: [partId], references: [id])
  movedBy User    @relation("StockMovementMovedBy", fields: [movedById], references: [id])

  @@index([companyId, branchId, partId, movedAt])
  @@index([companyId, movementType, movedAt])
  @@index([refType, refId])
  @@map("stock_movements")
}
